{
  "name": "surzo-desktop",
  "version": "0.2.12",
  "description": "Surzo – PC work tracker",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,lime \"vite --port 5173 --strictPort\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^32.2.5",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "jp.surzo.desktop",
    "productName": "Surzo",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "zip", "arch": "arm64" },
        { "target": "dmg", "arch": "arm64" }
      ],
      "icon": "build/icon.icns"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png"
    ]
  }
}
